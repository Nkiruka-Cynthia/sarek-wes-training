/*
 ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    sarek-wes-training — Nextflow configuration
    WES variant analysis pipeline optimized for 30-minute practical
 ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

nextflow.enable.dsl = 2

params {
    // Base parameters
    input              = "${launchDir}/data/samplesheet.csv"
    outdir             = "${launchDir}/results"
    
    // Reference genome (GRCh38)
    genome             = "GRCh38"
    igenomes_base      = 's3://ngi-igenomes/igenomes'
    
    // Sarek defaults optimized for training
    tools              = "strelka,vep"
    split_fastq        = 0           // No FASTQ splitting
    trim_fastq         = false       // No trimming (test data is clean)
    skip_tools         = "baserecalibrator"  // Skip BQSR (saves time)
    
    // Resource limits for Codespaces
    max_cpus           = 4
    max_memory         = '15.GB'
    max_time           = '4.h'
}

process {
    cpus               = 2
    memory             = '4.GB'
    time               = '1.h'
    errorStrategy      = { task.exitStatus in [143, 137, 104, 134, 139] ? 'retry' : 'finish' }
    maxRetries         = 1
}

profiles {
    conda {
        conda.enabled  = true
        docker.enabled = false
        singularity.enabled = false
    }
    
    test_wes {
        params {
            config_profile_name        = 'WES Test Profile (30-min Practical)'
            config_profile_description = 'Lightweight WES test dataset for training'
            
            // nf-core test data URLs
            input = "${projectDir}/data/samplesheet.csv"
            
            // WES-specific settings
            tools = "strelka,vep"
            skip_tools = "baserecalibrator"
            wes = true
        }
        
        process {
            cpus   = 2
            memory = '4.GB'
            time   = '30.min'
            
            withName: 'BWAMEM.*' {
                cpus = 2
                memory = '4.GB'
            }
            withName: 'GATK4_MARKDUPLICATES' {
                cpus = 2
                memory = '4.GB'
            }
            withName: 'STRELKA.*' {
                cpus = 2
                memory = '4.GB'
            }
            withName: 'ENSEMBLVEP_VEP' {
                cpus = 2
                memory = '4.GB'
            }
        }
    }
    
    docker {
        docker.enabled      = true
        docker.runOptions   = '-u $(id -u):$(id -g)'
        singularity.enabled = false
        conda.enabled       = false
    }
}

timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}
report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}
trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/trace.txt"
    overwrite = true
}

manifest {
    name            = 'sarek-wes-training'
    description     = 'WES variant analysis with Sarek — 30-minute practical for STaiMIC training'
    version         = '1.0.0'
    nextflowVersion = '>=25.10.0'
    mainScript      = 'main.sh'
    defaultBranch   = 'main'
}
